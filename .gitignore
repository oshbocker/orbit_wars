# Generated outputs — never commit model weights or logs
outputs/checkpoints/
outputs/logs/
outputs/submissions/

# Allow the placeholder files
!outputs/checkpoints/.gitkeep
!outputs/logs/.gitkeep
!outputs/submissions/.gitkeep

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.env
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Weights & Biases
wandb/
.wandb/

# Large notebook outputs (the tutorial notebook has 51 MB of embedded renders)
# To strip outputs: jupyter nbconvert --clear-output --inplace notebooks/*.ipynb
game_replay.html
# Generated HTML game replays (multi-MB each)
game_replay*.html
replay_*.html

# Local Claude Code settings
.claude/

# Experiment artifacts — keep configs + reports (*.md), drop heavy generated files
experiments/checkpoints/
experiments/logs/
experiments/plots/
experiments/plots2/
experiments/*.pkl
experiments/*.log
experiments/results.json
experiments/margin_vs_apex.json

# Research paper PDFs (downloaded locally; keep the .md write-ups)
rl_research/*.pdf

# Arena logs (CSV results are tracked; logs are not)
outputs/arena/*.log
