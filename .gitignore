# Generated outputs — never commit model weights or logs
outputs/checkpoints/
outputs/logs/
outputs/submissions/

# Allow the placeholder files
!outputs/checkpoints/.gitkeep
!outputs/logs/.gitkeep
!outputs/submissions/.gitkeep

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.env
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Weights & Biases
wandb/
.wandb/

# Large notebook outputs (the tutorial notebook has 51 MB of embedded renders)
# To strip outputs: jupyter nbconvert --clear-output --inplace notebooks/*.ipynb
game_replay.html
# Generated HTML game replays (multi-MB each)
game_replay*.html
replay_*.html

# Local Claude Code settings (but keep shared skills versioned)
.claude/*
!.claude/skills/

# Experiment artifacts — keep configs + reports (*.md), drop heavy generated files
experiments/checkpoints/
experiments/logs/
experiments/plots/
experiments/plots2/
experiments/*.pkl
experiments/*.log
experiments/results.json
experiments/margin_vs_apex.json

# Research paper PDFs (downloaded locally; keep the .md write-ups)
rl_research/*.pdf

# Arena logs (CSV results are tracked; logs are not)
outputs/arena/*.log
# throwaway 4P anchor-sweep experiment CSVs (not the tracked arena infra):
outputs/arena/4p_anchor_*.csv

# Generated/collected data + downloaded caches — keep reports (*.md) + arena CSVs.
# (git ignores have no inline comments — keep each pattern on its own line.)
# downloaded Kaggle leaderboard/episode cache:
outputs/replay_pulse/cache/
# generated BC datasets (*.npz):
outputs/macro_bc/
outputs/winbc/
# win-weighted BC shards (built on Colab; can be 100s of MB):
outputs/shards/
# raw collected game data (*.npz):
outputs/validator/raw/
outputs/value/raw/
# generated model weights:
outputs/**/*weights*.npz
# stray logs anywhere under outputs/:
outputs/**/*.log
